{
  "name": "group44-literature-intelligence-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173 --mode user",
    "dev:admin": "vite --host 0.0.0.0 --port 8080 --mode admin",
    "build": "npm run build:user && npm run build:admin",
    "build:user": "vue-tsc --noEmit && vite build --mode user",
    "build:admin": "vue-tsc --noEmit && vite build --mode admin",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "lint": "eslint src --ext .vue,.ts --fix"
  },
  "dependencies": {
    "@antv/g6": "^5.0.49",
    "@element-plus/icons-vue": "^2.3.1",
    "@vueuse/core": "^12.5.0",
    "axios": "^1.7.9",
    "echarts": "^5.6.0",
    "element-plus": "^2.9.3",
    "katex": "^0.16.18",
    "markdown-it": "^14.1.0",
    "markdown-it-katex": "^2.0.3",
    "pdfjs-dist": "^4.10.38",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0"
  }
