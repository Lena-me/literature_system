cat > .gitignore << 'EOF'
# Dependencies
node_modules/


# Environment
.env
.env.docker

# Build outputs
frontend/dist/
frontend/dist-user/
frontend/dist-admin/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Runtime outputs
runtime/
mineru_outputs/
hf_cache/

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db
EOF
