APP_NAME=科研文献智能解析与知识服务系统后端
APP_ENV=development
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MySQL（本地）
MYSQL_DSN=mysql+aiomysql://root:password@127.0.0.1:3306/literature_system?charset=utf8mb4

# Redis / Celery（本地）
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# MinIO（本地）
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PAPERS=paper-pdf
MINIO_BUCKET_EXPORTS=paper-exports
MINIO_SECURE=false

# Milvus（本地）
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=paper_chunks
MILVUS_VECTOR_DIM=1024
MILVUS_INDEX_TYPE=HNSW
MILVUS_METRIC_TYPE=COSINE

# 模型缓存目录（跨平台兼容，也可通过 HF_HOME 环境变量覆盖）
HF_CACHE_DIR=./runtime/hf_cache
BGE_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
BGE_RERANKER_MODEL=BAAI/bge-reranker-large
EMBEDDING_DEVICE=cpu
RERANKER_DEVICE=cpu

# LLM
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# Grobid
GROBID_BASE_URL=http://127.0.0.1:8070

# 分块与检索
CHUNK_SIZE=900
CHUNK_OVERLAP=120
TOP_K=8
RERANK_TOP_N=5

# Demo
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin123456

# 上传与备份（Windows 兼容相对路径）
UPLOAD_TMP_DIR=./runtime/uploads
MILVUS_BACKUP_DIR=./runtime/milvus_backups
# 文档要求增强项
VERIFICATION_CODE_TTL_SECONDS=300
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
DEFAULT_SINGLE_FILE_MAX_MB=200
DEFAULT_TOTAL_PAPERS=1000
DEFAULT_DAILY_QA_CALLS=200
DEFAULT_CONCURRENT_TASKS=5
