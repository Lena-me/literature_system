APP_NAME=科研文献智能解析与知识服务系统后端
APP_ENV=development
API_V1_PREFIX=/api/v1
SECRET_KEY=local-dev-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# ==================== MySQL ====================
MYSQL_DSN=mysql+aiomysql://paper_user:paper_pass@127.0.0.1:3306/literature_system?charset=utf8mb4
MYSQL_POOL_PRE_PING=true
MYSQL_POOL_SIZE=5
MYSQL_MAX_OVERFLOW=10

# ==================== Redis / Celery ====================
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ==================== MinIO ====================
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PAPERS=paper-pdf
MINIO_BUCKET_EXPORTS=paper-exports
MINIO_SECURE=false

# ==================== Milvus ====================
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=paper_chunks

# ==================== 文档解析 ====================
DOCUMENT_PARSER=hybrid
GROBID_BASE_URL=http://127.0.0.1:8070
# 如需 MinerU（需先 pip install mineru[all]，然后改 DOCUMENT_PARSER=mineru 或 hybrid）
MINERU_COMMAND=mineru
MINERU_BACKEND=pipeline
EMBEDDING_DEVICE=cpu
MINERU_METHOD=auto
MINERU_LANGUAGE=ch
MINERU_OUTPUT_DIR=./runtime/mineru_outputs
MINERU_TIMEOUT_SECONDS=900
MINERU_KEEP_OUTPUT=true
MINERU_FALLBACK_TO_GROBID=true

# ==================== HuggingFace / BGE ====================
HF_ENDPOINT=https://hf-mirror.com
HF_CACHE_DIR=./runtime/hf_cache
BGE_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
BGE_RERANKER_MODEL=BAAI/bge-reranker-large
EMBEDDING_DEVICE=cpu
RERANKER_DEVICE=cpu
CHUNK_SIZE=900
CHUNK_OVERLAP=120
TOP_K=8
RERANK_TOP_N=5

# ==================== LLM ====================
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-24745623d5bb4b21bd9d85374627bbe6
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
ENABLE_LLM_EXTRACT=true

# ==================== Neo4j ====================
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jadmin

# ==================== Demo ====================
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin123456

# ==================== 系统配置 ====================
VERIFICATION_CODE_TTL_SECONDS=300
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
DEFAULT_SINGLE_FILE_MAX_MB=200
DEFAULT_TOTAL_PAPERS=1000
DEFAULT_DAILY_QA_CALLS=200
DEFAULT_CONCURRENT_TASKS=5
UPLOAD_TMP_DIR=./runtime/uploads
MILVUS_BACKUP_DIR=./runtime/milvus_backups
