APP_NAME=科研文献智能解析与知识服务系统后端
APP_ENV=docker
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://frontend

MYSQL_DSN=mysql+aiomysql://paper_user:paper_pass@mysql:3306/literature_system?charset=utf8mb4
MYSQL_POOL_PRE_PING=true
MYSQL_POOL_SIZE=5
MYSQL_MAX_OVERFLOW=10
MYSQL_POOL_RECYCLE_SECONDS=1800
MYSQL_POOL_TIMEOUT_SECONDS=30
MYSQL_CONNECT_TIMEOUT_SECONDS=10
MYSQL_CONNECT_RETRIES=3
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PAPERS=paper-pdf
MINIO_BUCKET_EXPORTS=paper-exports
MINIO_SECURE=false

MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=paper_chunks
MILVUS_VECTOR_DIM=1024
MILVUS_INDEX_TYPE=HNSW
MILVUS_METRIC_TYPE=COSINE

# Document Parser: mineru / grobid / hybrid
DOCUMENT_PARSER=hybrid
MINERU_COMMAND=magic-pdf
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_LANGUAGE=ch
MINERU_OUTPUT_DIR=/app/runtime/mineru_outputs
MINERU_TIMEOUT_SECONDS=900
MINERU_KEEP_OUTPUT=true
MINERU_FALLBACK_TO_GROBID=true

GROBID_BASE_URL=http://grobid:8070
HF_ENDPOINT=https://hf-mirror.com
HF_HOME=/app/hf_cache
HF_CACHE_DIR=/app/hf_cache
BGE_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
BGE_RERANKER_MODEL=BAAI/bge-reranker-large
EMBEDDING_DEVICE=cpu
RERANKER_DEVICE=cpu
CHUNK_SIZE=900
CHUNK_OVERLAP=120
TOP_K=8
RERANK_TOP_N=5

LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-bf3bf1370ca94b7196c1fe8ab658fae5
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# ===== 新增 Neo4j 配置 =====
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jadmin

DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin123456

# 文档要求增强项：验证码、账号锁定、分片续传、资源配额、向量库备份恢复
VERIFICATION_CODE_TTL_SECONDS=300
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
DEFAULT_SINGLE_FILE_MAX_MB=200
DEFAULT_TOTAL_PAPERS=1000
DEFAULT_DAILY_QA_CALLS=200
DEFAULT_CONCURRENT_TASKS=5
UPLOAD_TMP_DIR=/app/runtime/uploads
MILVUS_BACKUP_DIR=/app/runtime/milvus_backups
MILVUS_BACKUP_COMMAND=
MILVUS_RESTORE_COMMAND=

# QA Agent (LangGraph)
QA_USE_LANGGRAPH=true
QA_HISTORY_LIMIT=20

DOCUMENT_PARSER=hybrid